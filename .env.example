# Secret serveur uniquement. Ne jamais préfixer par NEXT_PUBLIC_.
KEEPA_API_KEY=
# Pour ventiler le forfait dans le coût par alerte (80 € = 8000 centimes).
KEEPA_MONTHLY_COST_CENTS=8000

# Signe l’identité appareil (HMAC-SHA256). Au moins 32 caractères aléatoires.
# Exemple de génération : openssl rand -base64 32
DEVICE_COOKIE_SECRET=

# Secret partagé avec le collecteur. Au moins 24 caractères aléatoires.
INGEST_SECRET=

# Secret distinct, réservé à la lecture des cibles et à l’audit Web Push.
PUSH_DELIVERY_SECRET=

# Clés Web Push VAPID. La clé privée reste côté serveur/collecteur.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# URL absolue de la version publiée, utilisée par les cartes sociales.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Centre de pilotage : protéger /api/admin/* avec une application Cloudflare Access.
# Le domaine ressemble à equipe.cloudflareaccess.com et AUD est le tag d'audience Access.
# ADMIN_EMAILS reste une seconde liste blanche applicative, séparée par des virgules.
ADMIN_EMAILS=
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# Les alertes sont analysées et auditées en shadow, mais aucun Push réel n'est envoyé.
# Passer à live uniquement après recette des preuves et du taux de faux positifs.
ALERT_DELIVERY_MODE=shadow

# Optionnel : tag Partenaire Amazon. Les liens ne sont utilisés qu’avec le consentement utilisateur.
AMAZON_ASSOCIATE_TAG=
