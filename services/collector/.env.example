# Runtime
NODE_ENV=development
LOG_LEVEL=info
REDIS_URL=redis://127.0.0.1:6379
ENABLE_BROWSER_FALLBACK=false
COLLECTOR_HTTP_TIMEOUT_MS=15000
VERIFY_DELAY_MS=2500
MAX_DISCOVERED_URLS=100
PROXY_URLS=
# Live access is denied by default for these partner sources. Add only source
# identifiers covered by an explicit merchant/partner authorization.
# Allowed values: fnac,carrefour,leroy_merlin,castorama,conforama,rueducommerce
AUTHORIZED_PARTNER_SOURCES=

# PrixRadar private Sites API. Server-side values only.
PRICE_RADAR_BASE_URL=https://example.openai.site
INGEST_SECRET=
PUSH_DELIVERY_SECRET=
# Optional extra authentication required by a private OpenAI Site.
OAI_SITES_AUTH_TOKEN=

# Keepa EU5: GB, DE, FR, IT and ES.
KEEPA_API_KEY=
KEEPA_MARKETS=FR,DE,IT,ES,GB
KEEPA_MAX_QUOTA_WAIT_MS=60000

# Web Push. Generate once with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:alerts@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Actor fixtures are accepted for extraction tests only. Fixture observations
# are rejected by sink and push regardless of this environment.
APIFY_DEFAULT_DATASET_ID=

# Used only by the local provisioning command, never exposed to the PWA.
APIFY_TOKEN=
APIFY_ACTOR_ID=
# Comma or newline-separated category/search pages explicitly chosen for discovery.
PRIXRADAR_RETAIL_URLS=
